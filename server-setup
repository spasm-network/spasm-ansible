#!/usr/bin/env bash
# Orchestrator: import GPG key, fetch/verify repo, run init
set -euo pipefail

echo "----------------------------------------------------"
echo "Starting full server setup"

# Parse args
AUTO_UPDATE=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --auto-update) AUTO_UPDATE=true; shift;;
    *) echo "Unknown arg: $1"; exit 1;;
  esac
done

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Change to safe directory immediately (cwd may be deleted during repo swap)
cd "${SCRIPT_DIR}"

bash "${SCRIPT_DIR}/import-gpg"

bash "${SCRIPT_DIR}/fetch-verify-repo"

# Change to safe directory again after swap (cwd may have been deleted)
cd "${SCRIPT_DIR}"

if [[ "${AUTO_UPDATE}" == "true" ]]; then
  bash "${SCRIPT_DIR}/init" --auto-update
else
  bash "${SCRIPT_DIR}/init"
fi

echo "Full server setup finished"
echo "----------------------------------------------------"
