#!/usr/bin/env bash
# scripts/import-gpg.sh
# Non-interactive idempotent import of embedded GPG public key.
# Run as root (direct or via sudo) to import into root, admin, and user keyrings.
# Run as non-root to import into caller's keyring only.
set -euo pipefail

WORK_DIR="$(mktemp -d)"
KEY_FILE="${WORK_DIR}/spasm-operator.pub.asc"

cat > "${KEY_FILE}" <<'EOF'
-----BEGIN PGP PUBLIC KEY BLOCK-----

mDMEXp05whYJKwYBBAHaRw8BAQdAx4t0Zss1dqJlUKrbc5vMtI/N0ZYMqGABycOo
K5MmuS2IywQfFgoAfQWCXp05wgMLCQcJEBmJZCH0rp6kRxQAAAAAAB4AIHNhbHRA
bm90YXRpb25zLnNlcXVvaWEtcGdwLm9yZ5OB2uWPxYoTXSe0jBgI3299NsJdRx6w
7a87G77jOS56AxUKCAKbAwIeARYhBA3qF0OmdC8lz4Ok5RmJZCH0rp6kAABd9gD/
aVOx6doEU9d7VquPXJH02+l6qmcjhbX7hvPWuz74USQA+wReoICBlk355AYkvYXO
L4dZl1/2X3t8nIm7H2SMdiQPtCdkZWdlbnJvY2tldCA8bm9yZXBseUBkZWdlbnJv
Y2tldC5zcGFjZT6IkwQTFgoAOxYhBA3qF0OmdC8lz4Ok5RmJZCH0rp6kBQJkRJUe
AhsDBQsJCAcCAiICBhUKCQgLAgQWAgMBAh4HAheAAAoJEBmJZCH0rp6kl3gA/3Ah
rnK0vyPWuRVsLRoMovQtEGNfFrHtBiIx1IDsbOY5AQCEaDZ1OsAId9vaKdP1abXo
xOBfUka/4EVIP0nW8ioYDbg4BF6dOcISCisGAQQBl1UBBQEBB0BV/39B5T6ufCng
QjVNqZBZHufyAR3ey/sc6q+dbeKqRQMBCAeIwwQYFgoAdQWCXp05wgkQGYlkIfSu
nqRHFAAAAAAAHgAgc2FsdEBub3RhdGlvbnMuc2VxdW9pYS1wZ3Aub3JnFD4GH7+G
P3AQktWn+fSb4kDuNECnUre7x16Nk9PzSfYCmwgCHgEWIQQN6hdDpnQvJc+DpOUZ
iWQh9K6epAAASxwBAK58/AXXh35J/bWBlyfo+f9Co5lbCSur6p1N/OMnTM5YAQCx
NhvV3CpqJHGPd5W6qobN+IABW1eTv2x3XPvimoPfCg==
