#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE}")/../.." && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
ENV_FILE="$PROJECT_ROOT/.env"

if [ -f "$ENV_FILE" ]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
else
  echo "Error: .env not found at $ENV_FILE"
  exit 1
fi

echo "=== Let's Encrypt Certificate Renewal ==="
echo "Domain: ${domain:-<unset>}"
echo ""

CERTBOT_BIN="$(command -v certbot || true)"
if [ -z "$CERTBOT_BIN" ]; then
  echo "Error: certbot not found in PATH"
  exit 1
fi

echo "[*] Running certbot renew..."
if ! "$CERTBOT_BIN" renew --quiet; then
  echo "[✗] Renewal check failed; see /var/log/letsencrypt/renew.log"
  exit 1
fi
echo "[✓] Renewal check completed"

CERT_PATH="/etc/letsencrypt/live/${domain}/cert.pem"
if [[ ! -f "$CERT_PATH" ]]; then
  echo "[✗] Certificate not found: $CERT_PATH"
  exit 1
fi

EXPIRY_DATE=$(openssl x509 -enddate -noout -in "$CERT_PATH" | cut -d= -f2)
EXPIRY_EPOCH=$(date -d "$EXPIRY_DATE" +%s)
NOW_EPOCH=$(date +%s)
DAYS_LEFT=$(( ($EXPIRY_EPOCH - $NOW_EPOCH) / 86400 ))

echo ""
echo "[✓] Certificate expires: $EXPIRY_DATE"
echo "[✓] Days remaining: $DAYS_LEFT"

if [[ $DAYS_LEFT -lt 7 ]]; then
  echo "[!] WARNING: Certificate expires in less than 7 days!"
  exit 1
fi

echo ""
echo "[✓] Certificate renewal check completed successfully"
